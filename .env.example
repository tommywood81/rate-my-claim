# Rate My Claim — local development (copy to .env, never commit .env)
# docker compose loads this file for backend, celery, and frontend.

# --- Security ---
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long

# --- AI ---
OPENAI_API_KEY=
# AI_PROVIDER=openai
# OLLAMA_BASE_URL=http://host.docker.internal:11434

OPENAI_ENFORCE_TOKEN_BUDGETS=true
OPENAI_MAX_TOKENS_PER_DAY=200000
OPENAI_MAX_TOKENS_PER_CLAIM_SCOPE=80000
# Min cosine similarity to borrow another claim's evidence during enrichment (0–1).
# Prefer tuning retrieval.min_similarity in backend/config/enrichment_pipeline.yaml.
ENRICHMENT_RETRIEVAL_MIN_SIMILARITY=0.72
# Optional override path for pipeline YAML (parallel crawl, AI caps, etc.).
# ENRICHMENT_PIPELINE_CONFIG=/app/config/enrichment_pipeline.yaml

# --- Database ---
POSTGRES_USER=rmc
POSTGRES_PASSWORD=rmc_dev_password
POSTGRES_DB=rate_my_claim
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://rmc:rmc_dev_password@postgres:5432/rate_my_claim
DATABASE_SYNC_URL=postgresql+psycopg2://rmc:rmc_dev_password@postgres:5432/rate_my_claim

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- App URLs ---
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
PUBLIC_APP_URL=http://localhost:8080
COOKIE_SECURE=false
# COOKIE_DOMAIN=

HTTP_PORT=8080
INTERNAL_API_URL=http://backend:8000

# --- Observability (optional) ---
# OTEL_ENABLED=false
# OTEL_ENVIRONMENT=development
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# LOG_JSON=true
# LOG_LEVEL=INFO

# --- Seed (optional) ---
# SEED_DEVELOPMENT=true
# SEED_PASSWORD=SeedDev!ChangeMe123

# --- Grafana (observability profile) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me
