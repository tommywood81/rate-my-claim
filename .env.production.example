# Rate My Claim — production template (copy to .env on the host, never commit secrets)

APP_VERSION=1.0.0
OTEL_ENVIRONMENT=production

SECRET_KEY=REPLACE_WITH_SECRET_MANAGER_VALUE
OPENAI_API_KEY=REPLACE_WITH_SECRET_MANAGER_VALUE

POSTGRES_USER=rmc
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=rate_my_claim

DATABASE_URL=postgresql+asyncpg://rmc:REPLACE@postgres:5432/rate_my_claim
DATABASE_SYNC_URL=postgresql+psycopg2://rmc:REPLACE@postgres:5432/rate_my_claim

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CORS_ORIGINS=https://your-domain.example
PUBLIC_APP_URL=https://your-domain.example
COOKIE_SECURE=true
COOKIE_DOMAIN=your-domain.example

HTTP_PORT=80
HTTPS_PORT=443

# Frontend SSR → backend (Docker network)
INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_SITE_URL=https://your-domain.example

LOG_JSON=true
LOG_LEVEL=INFO

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

OPENAI_ENFORCE_TOKEN_BUDGETS=true
OPENAI_MAX_TOKENS_PER_DAY=500000
OPENAI_MAX_TOKENS_PER_CLAIM_SCOPE=120000

# TLS certificate paths (mounted into nginx container)
# NGINX_SSL_CERT=/etc/nginx/certs/fullchain.pem
# NGINX_SSL_KEY=/etc/nginx/certs/privkey.pem
